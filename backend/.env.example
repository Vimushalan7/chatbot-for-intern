# ══════════════════════════════════════════════════════════════════════════════
# .env — Backend Environment Variables
# Copy this file to .env and adjust the values.
# NEVER commit .env to Git (it's in .gitignore).
# ══════════════════════════════════════════════════════════════════════════════

# ── Ollama Configuration ───────────────────────────────────────────────────────
# Make sure Ollama is installed and running: https://ollama.ai
# Pull models with: ollama pull llama3.2  &&  ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Storage ───────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
UPLOAD_DIR=./data/uploads

# ── RAG Tuning ────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# ── App Settings ──────────────────────────────────────────────────────────────
DEBUG=false
MAX_FILE_SIZE_MB=50

# ── Cloud LLM Providers ────────────────────────────────────────────────────────
# Add your API keys here for cloud-hosted model providers.
# Setting ANTHROPIC_API_KEY will prioritize Claude models (e.g. claude-3-5-sonnet-latest).
# Setting GROQ_API_KEY will prioritize Groq hosted models (e.g. llama-3.3-70b-versatile).

# Anthropic Claude Configuration
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_MODEL=claude-3-5-sonnet-latest

# Groq Cloud Configuration
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

